{
  "name": "lrc-studio-server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.3.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@crimson-carnival/ds-js": "1.0.2",
    "@fastify/compress": "8.3.1",
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "10.1.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/multipart": "10.0.0",
    "@fastify/rate-limit": "10.3.0",
    "@simplewebauthn/server": "13.3.0",
    "argon2": "0.44.0",
    "cloudinary": "2.10.0",
    "dotenv": "16.6.1",
    "fastify": "5.8.5",
    "fastify-plugin": "5.1.0",
    "graphql": "16.14.0",
    "i18next": "26.3.0",
    "jsonwebtoken": "9.0.3",
    "mercurius": "16.9.0",
    "mongoose": "8.24.0",
    "nanoid": "5.1.11",
    "pino-pretty": "13.1.3",
    "sanitize-html": "2.17.4",
    "socket.io": "4.8.3",
    "ua-parser-js": "2.0.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "bcrypt",
      "esbuild",
      "mongodb-memory-server"
    ]
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.9.1",
    "@types/sanitize-html": "2.16.1",
    "@types/ua-parser-js": "0.7.39",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "9.39.4",
    "globals": "17.6.0",
    "mongodb-memory-server": "11.1.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7"
  }
}
