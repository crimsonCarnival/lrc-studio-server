    "bcrypt": "^5.1.1",
    "cloudinary": "^2.6.1",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.1.0",
    "fastify-socket.io": "^5.1.0",
